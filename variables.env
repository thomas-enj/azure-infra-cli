# Deployment region
AZURE_LOCATION=francecentral

# Resource group name and shared resource group name
RESOURCE_GROUP=tenjalbertRG
RG_SHARED=rg-shared-prf2026
APP_PLAN_NAME=plan-npr-prf2026

# Contributor name
NAME=thomas
FULL_NAME=thomas-enjalbert

# Tags for all resources (for the Friday cleanup)
TAGS="managed_by=cli environment=tp owner=${FULL_NAME}"

# Noms des ressources réseau
VNET_NAME="vnet-${FULL_NAME}-cli"
NSG_NAME="nsg-frontend-${FULL_NAME}-cli"

# Storage account variables
STORAGE_ACCOUNT_NAME=st${NAME}prf2026

# App Service variables
APP_SERVICE_PLAN=plan-npr-prf2026
APP_NAME=api-appservice-${NAME}
RUNTIME="PHP|8.2"

# Function App variables
FUNCTION_APP_NAME=api-func-${NAME}
RUNTIME_OS=linux
RUNTIME_FUNCTION=python
RUNTIME_VERSION=3.11
